---
import PageLayout from '@/layouts/BaseLayout.astro'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const sections = [
  { title: 'С чего начать',        description: 'Роль, правила, первый день',             href: `${base}/docs/start/index`,                icon: '📋' },
  { title: 'Подготовка смены',     description: 'Зарядка АКБ, техпомещение, что взять',   href: `${base}/docs/daily/preparation`,          icon: '🔋' },
  { title: 'Замена АКБ',           description: 'Пошагово за 30 секунд',                  href: `${base}/docs/daily/battery-swap`,         icon: '⚡' },
  { title: 'Ежедневные проверки',  description: 'Чеклист на каждую смену',                href: `${base}/docs/daily/daily-checks`,         icon: '✅' },
  { title: 'Снегокат не едет',     description: 'Диагностика — от простого к сложному',   href: `${base}/docs/troubleshooting/not-moving`, icon: '🔧' },
  { title: 'АКБ: правила',         description: 'Зарядка, хранение, безопасность',        href: `${base}/docs/battery/rules`,              icon: '🛡️' },
  { title: 'Погода и покрытие',    description: 'Снег, оттепель, лёд, слякоть',           href: `${base}/docs/weather/conditions`,         icon: '🌨️' },
  { title: 'Еженедельные проверки',description: 'Салазки, зона, отчёт',                   href: `${base}/docs/weekly/checks`,              icon: '📅' },
  { title: 'Видеоинструкции',      description: 'Смотреть перед первой сменой',           href: `${base}/docs/videos/index`,               icon: '🎬' },
  { title: 'Поддержка',            description: 'Куда писать, если что-то пошло не так',  href: `${base}/docs/support/contacts`,           icon: '💬' },
]
---

<PageLayout meta={{ title: 'База знаний сотрудника' }}>
  <main class='flex w-full flex-col items-center'>

    <section class='animate mb-8 flex flex-col items-center gap-y-5 text-center' id='content-header'>
      <div class='text-5xl'>🐋</div>
      <h1 class='text-3xl font-medium'>Кашалот — база знаний</h1>
      <p class='text-muted-foreground max-w-md'>
        Операционный справочник для сотрудников. Изучи всё перед первой сменой —
        и возвращайся, когда что-то нужно уточнить прямо на точке.
      </p>
      <div class='flex items-center gap-x-2 rounded-full border bg-amber-50 dark:bg-amber-950 border-amber-200 dark:border-amber-800 px-4 py-2 text-sm text-amber-800 dark:text-amber-200'>
        <span>⚡</span>
        <span>Главное правило: АКБ 40–50% → меняем сразу</span>
      </div>
    </section>

    <div id='content' class='animate w-full md:w-4/5 lg:w-5/6'>

      <!-- Поиск -->
      <div class='relative mb-6'>
        <svg class='pointer-events-none absolute left-3.5 top-1/2 -translate-y-1/2 size-4 text-muted-foreground' xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
          <circle cx='11' cy='11' r='8'/><path d='m21 21-4.35-4.35'/>
        </svg>
        <input
          id='search-input'
          type='search'
          autocomplete='off'
          placeholder='Найти инструкцию… например «замена АКБ»'
          class='w-full rounded-xl border bg-muted py-3 pl-10 pr-4 text-sm outline-none ring-0 transition-colors focus:border-primary'
        />
      </div>

      <!-- Результаты поиска -->
      <div id='search-results' class='hidden mb-6 flex flex-col gap-2'></div>

      <!-- Нет результатов -->
      <div id='search-empty' class='hidden mb-6 rounded-xl border border-dashed px-4 py-3 text-sm'>
        <p class='text-muted-foreground'>Ничего не найдено — возможно, этого раздела ещё нет в базе знаний.</p>
        <a href='https://t.me/franch_sup_bot' target='_blank' rel='noopener noreferrer'
           class='mt-1 inline-flex font-medium hover:underline'>💬 Написать в бот поддержки</a>
      </div>

      <!-- Карточки разделов -->
      <div id='sections-grid' class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
        {sections.map((s) => (
          <a href={s.href}
             class='flex items-start gap-x-4 rounded-2xl border bg-card p-4 text-card-foreground shadow-sm transition-all hover:shadow-md hover:border-primary/50'>
            <span class='text-2xl mt-0.5'>{s.icon}</span>
            <div>
              <div class='font-medium'>{s.title}</div>
              <div class='text-sm text-muted-foreground mt-0.5'>{s.description}</div>
            </div>
          </a>
        ))}
      </div>

      <div class='mt-8 flex justify-center'>
        <a href='https://t.me/franch_sup_bot' target='_blank'
           class='flex items-center gap-x-2 rounded-full border px-5 py-2.5 text-sm font-medium transition-colors hover:bg-muted'>
          <span>💬</span> Бот техподдержки
        </a>
      </div>
    </div>
  </main>
</PageLayout>

<script>
  const base      = import.meta.env.BASE_URL.replace(/\/$/, '')
  const TG_TOKEN  = import.meta.env.PUBLIC_TG_BOT_TOKEN   || ''
  const TG_CHAT   = import.meta.env.PUBLIC_TG_CHAT_ID     || ''
  const SHEETS_WH = import.meta.env.PUBLIC_SHEETS_WEBHOOK || ''

  const input   = document.getElementById('search-input')   as HTMLInputElement
  const results = document.getElementById('search-results') as HTMLElement
  const empty   = document.getElementById('search-empty')   as HTMLElement
  const grid    = document.getElementById('sections-grid')  as HTMLElement

  let pagefind: any = null
  let debounceTimer: ReturnType<typeof setTimeout>
  let tgTimer:      ReturnType<typeof setTimeout>
  let lastSent = ''

  async function getPF() {
    if (pagefind) return pagefind
    pagefind = await import(`${base}/pagefind/pagefind.js`)
    await pagefind.options({ excerptLength: 20 })
    return pagefind
  }

  function setMode(mode: 'idle' | 'results' | 'empty') {
    grid.style.display    = mode === 'idle' ? '' : 'none'
    results.classList.toggle('hidden', mode !== 'results')
    empty.classList.toggle('hidden',   mode !== 'empty')
  }

  function sendToTg(query: string, found: number) {
    if (!TG_TOKEN || !TG_CHAT) return
    if (query === lastSent) return   // не дублировать
    lastSent = query

    const icon   = found > 0 ? '🔍' : '❓'
    const status = found > 0 ? `Найдено: ${found}` : 'Ничего не найдено'
    const msg    = `${icon} <b>Поисковый запрос</b>\n«${query}»\n${status}`

    // Telegram — уведомление
    fetch(`https://api.telegram.org/bot${TG_TOKEN}/sendMessage`, {
      method : 'POST',
      headers: { 'Content-Type': 'application/json' },
      body   : JSON.stringify({ chat_id: TG_CHAT, text: msg, parse_mode: 'HTML' })
    }).catch(() => {})

    // Google Таблица — архив для аналитики
    if (SHEETS_WH) {
      fetch(SHEETS_WH, {
        method : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body   : JSON.stringify({
          query,
          found,
          status: found > 0 ? 'found' : 'not_found'
        })
      }).catch(() => {})
    }
  }

  async function runSearch(query: string) {
    if (!query) { setMode('idle'); lastSent = ''; return }

    const pf = await getPF()
    const { results: hits } = await pf.search(query)

    if (!hits.length) {
      setMode('empty')
      // Запросы без результатов — отправляем сразу (это и есть «дырки» в базе)
      clearTimeout(tgTimer)
      tgTimer = setTimeout(() => sendToTg(query, 0), 1500)
      return
    }

    const data = await Promise.all(hits.slice(0, 6).map((h: any) => h.data()))

    results.innerHTML = data.map((d: any) => `
      <a href="${d.url.replace(/\/$/, '')}"
         class="flex flex-col gap-y-0.5 rounded-xl border bg-card px-4 py-3 transition-all hover:shadow-md hover:border-primary/50">
        <span class="font-medium text-sm">${d.meta?.title ?? 'Без названия'}</span>
        <span class="text-xs text-muted-foreground line-clamp-2">${d.excerpt}</span>
      </a>
    `).join('')

    setMode('results')

    // Успешные запросы — отправляем после 4 сек паузы (человек нашёл что искал)
    clearTimeout(tgTimer)
    tgTimer = setTimeout(() => sendToTg(query, hits.length), 4000)
  }

  input.addEventListener('input', () => {
    clearTimeout(debounceTimer)
    clearTimeout(tgTimer)
    lastSent = ''
    debounceTimer = setTimeout(() => runSearch(input.value.trim()), 200)
  })
</script>
