---
import { PFSearch } from 'astro-pure/components/pages'
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import { integ } from '@/site-config'

const meta = {
  description: 'Search relative posts of the whole blog',
  title: 'Search'
}
---

<PageLayout {meta}>
  <Button title='Back' href='/blog' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium'>Search</h1>
    </div>

    <div id='content' class='animate'>
      {
        integ.pagefind ? (
          <>
            <p class='text-muted-foreground mb-4'>Введи слово или фразу — найдём в базе знаний.</p>
            <PFSearch />
            <div id='zero-results-hint' class='hidden mt-4 rounded-xl border border-dashed px-4 py-3 text-sm'>
              <p class='text-muted-foreground'>По запросу <strong id='zero-results-query'></strong> ничего не найдено.</p>
              <p class='mt-1'>Возможно, этого раздела ещё нет в базе знаний —
                <a href='https://t.me/franch_sup_bot' target='_blank' rel='noopener noreferrer'
                   class='font-medium hover:underline'>напиши в бот поддержки</a>,
                мы добавим.
              </p>
            </div>
          </>
        ) : (
          <p>Pagefind is disabled.</p>
        )
      }
    </div>
  </main>
</PageLayout>

<script>
  function initZeroResultsWatcher() {
    const hint = document.getElementById('zero-results-hint')
    const queryEl = document.getElementById('zero-results-query')
    if (!hint || !queryEl) return

    const showHint = (query: string) => {
      queryEl.textContent = `«${query}»`
      hint.classList.remove('hidden')
    }
    const hideHint = () => hint.classList.add('hidden')

    const checkResults = () => {
      const input = document.querySelector<HTMLInputElement>('.pagefind-ui__search-input')
      const message = document.querySelector('.pagefind-ui__message')
      if (!message || !input) return
      const query = input.value.trim()
      if (!query) { hideHint(); return }
      const text = message.textContent ?? ''
      const isZero = /\b0\b/.test(text) || text.toLowerCase().includes('no results')
      isZero ? showHint(query) : hideHint()
    }

    // Watch DOM for Pagefind rendering results
    const observer = new MutationObserver(checkResults)
    const startObserving = () => {
      const container = document.getElementById('site-search')
      if (container) observer.observe(container, { childList: true, subtree: true })
    }

    // Pagefind loads lazily — wait for it
    if (document.readyState === 'complete') startObserving()
    else window.addEventListener('load', startObserving)
  }

  initZeroResultsWatcher()
</script>
